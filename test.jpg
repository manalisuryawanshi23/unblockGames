 <style>
 body {
    padding-top: 0px;
    overflow: hidden;
    width: 100%;
    height: 100%;
}
img {
    padding-top: 0px;
    max-width:562px; 
    height:auto; 
    margin: 0 auto;
    text-align: center;
    display: block;
}
.container {
   position: relative;
   top: -20px;
}
.section__header {
    margin-bottom: 45px;
    margin-top: 0px;
}

.button_default {
    display: block;
    margin: 0 auto;
    width: 400px;
}
.dev-gamemonetize__title {
    font-size: 65px;
    margin-top: -20px;
}
.button_default {
      display: block;
    margin: 0 auto;
